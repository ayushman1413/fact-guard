# ====== REQUIRED API KEYS ======

# Groq API Key (Free tier - no billing required)
# Get it at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily API Key (Free tier available for search)
# Get it at: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ====== OPTIONAL: DATABASE ======

# MongoDB Atlas Connection String (optional - omit to run without persistence)
# Get it at: https://mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=Cluster0

# ====== DEPLOYMENT & FRONTEND ======

# Frontend URL (for CORS configuration)
# Local: http://localhost:5173
# Production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# Server Port
PORT=5000

# ====== OPTIMIZATION & TESTING ======

# Verification Mode: 'mock' | 'demo' | 'production'
# - 'mock': Use fake verdicts (NO API CALLS - perfect for testing without costs)
# - 'demo': Use real APIs but with optimizations
# - 'production': Full API usage
VERIFICATION_MODE=mock

# Maximum claims to extract per PDF (to reduce token usage)
MAX_CLAIMS_PER_PDF=10

# Delay between verification requests (milliseconds) to avoid rate limits
RATE_LIMIT_DELAY=300
